# Example environment variables for floatcast-ai
# Copy to `.env` and fill values before running locally. Do NOT commit secrets.

# Server-side (backend) environment variables (set these in your backend deployment)
# NVIDIA_API_KEY is required by the backend and must NOT be prefixed with VITE_
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Frontend environment variables (VITE_ prefix means they are exposed to the browser)
# VITE_PROXY_URL should be the full URL for your backend completions endpoint,
# including the path. Example: https://your-backend.vercel.app/api/chat/completions
VITE_PROXY_URL=https://floatcast-backend.vercel.app/api/chat/completions

# Optional UI settings
VITE_APP_NAME=FloatCast

# Optional: maximum tokens requested from the model for generation. Set to a high
# value only if your backend and model support it. The client will cap requests
# at a safe maximum to prevent accidental abuse.
# Example: 8192
VITE_MAX_TOKENS=8192
